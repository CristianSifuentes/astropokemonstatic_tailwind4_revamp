---
import MainLayout from "../../layouts/MainLayout.astro";
import PokemonCard from "../../components/PokemonCard.astro";
import CustomTitle from "../../components/CustomTitle.astro";
import type { PokemonListResponse } from "../../data/pokemon-list.response";

export const prerender = true;

export async function getStaticPaths() {
  const TOTAL_POKEMONS = 151;
  const totalPages = Math.ceil(TOTAL_POKEMONS / 20);

  return Array.from({ length: totalPages }).map((_, i) => ({
    params: { page: String(i + 1) },
  }));
}

const { page } = Astro.params;
const currentPage = Number(page ?? 1);

const response = await fetch(
  `https://pokeapi.co/api/v2/pokemon?limit=20&offset=${(currentPage - 1) * 20}`
);
const data: PokemonListResponse = await response.json();

const prev = currentPage > 1 ? `/pokemons/${currentPage - 1}` : null;
const next = currentPage < 8 ? `/pokemons/${currentPage + 1}` : null;
---

<MainLayout title={`Pokédex — Page ${currentPage}`}>
  <section class="space-y-6">
    <CustomTitle
      title={`Pokédex • Page ${currentPage}`}
      subtitle="A masonry-like list using Tailwind v4 columns — clean, responsive, and zero JavaScript."
    />

    <div class="glass rounded-[var(--radius-2xl)] p-4 sm:p-5">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <p class="text-sm text-white/70">
          Showing <span class="text-white">20</span> Pokémon per page.
          <span class="text-white/50"> Use the arrows to navigate.</span>
        </p>

        <div class="flex items-center gap-2">
          {prev ? (
            <a
              href={prev}
              class="inline-flex items-center justify-center rounded-xl bg-white/5 px-3 py-2 text-sm font-semibold text-white/80 ring-1 ring-white/10 hover:bg-white/10 hover:text-white transition focus-visible:focus-ring"
            >
              ← Prev
            </a>
          ) : (
            <span class="inline-flex items-center justify-center rounded-xl bg-white/5 px-3 py-2 text-sm text-white/35 ring-1 ring-white/10">
              ← Prev
            </span>
          )}

          {next ? (
            <a
              href={next}
              class="inline-flex items-center justify-center rounded-xl bg-white px-3 py-2 text-sm font-semibold text-black shadow-sm shadow-black/30 hover:translate-y-[-1px] hover:shadow-md transition focus-visible:focus-ring"
            >
              Next →
            </a>
          ) : (
            <span class="inline-flex items-center justify-center rounded-xl bg-white/5 px-3 py-2 text-sm text-white/35 ring-1 ring-white/10">
              Next →
            </span>
          )}
        </div>
      </div>
    </div>

    <!-- Masonry list via columns -->
    <div class="columns-1 gap-4 sm:columns-2 sm:gap-5 lg:columns-3 xl:columns-4">
      {data.results.map((pokemon) => (
        <div class="mb-4 break-inside-avoid sm:mb-5">
          <PokemonCard
            name={pokemon.name}
            id={pokemon.url.split("/").at(-2)}
            image={`https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/official-artwork/${pokemon.url.split("/").at(-2)}.png`}
          />
        </div>
      ))}
    </div>

    <div class="glass rounded-[var(--radius-2xl)] p-4 sm:p-5">
      <div class="flex items-center justify-between">
        <p class="text-sm text-white/70">
          Page <span class="text-white">{currentPage}</span> of <span class="text-white">8</span>
        </p>

        <div class="flex items-center gap-2">
          {prev && (
            <a
              href={prev}
              class="rounded-xl bg-white/5 px-3 py-2 text-sm text-white/80 ring-1 ring-white/10 hover:bg-white/10 hover:text-white transition focus-visible:focus-ring"
            >
              ←
            </a>
          )}
          {next && (
            <a
              href={next}
              class="rounded-xl bg-white/5 px-3 py-2 text-sm text-white/80 ring-1 ring-white/10 hover:bg-white/10 hover:text-white transition focus-visible:focus-ring"
            >
              →
            </a>
          )}
        </div>
      </div>
    </div>
  </section>
</MainLayout>
