---
import MainLayout from "../layouts/MainLayout.astro";
import CustomTitle from "../components/CustomTitle.astro";
---

<!-- About route documents architecture decisions and styling strategy. -->
<MainLayout title="About — Astro Pokédex" description="Design notes for the Astro + Tailwind v4 Pokédex demo.">
  <section class="space-y-8">
    <CustomTitle
      title="Design notes"
      subtitle="A tiny reference app that focuses on layout primitives: display, flex, grid, and columns — with modern motion and accessibility."
    />

    <div class="grid gap-6 lg:grid-cols-12">
      <div class="lg:col-span-7 glass rounded-[var(--radius-2xl)] p-6 sm:p-8">
        <h2 class="text-lg font-semibold">Why columns?</h2>
        <p class="mt-3 text-sm text-white/70">Tailwind’s <code class="rounded bg-black/30 px-1.5 py-0.5 text-white/80">columns-*</code> utilities are a clean way to get a masonry-like layout without JS. Combine them with <code class="rounded bg-black/30 px-1.5 py-0.5 text-white/80">break-inside-avoid</code> so each card stays intact.</p>

        <!-- Dummy blocks emulate uneven card heights to show masonry behavior. -->
        <div class="mt-6 columns-2 gap-4 sm:columns-3">
          {Array.from({ length: 6 }).map((_, i) => (
            <div class="mb-4 break-inside-avoid glass rounded-2xl p-4">
              <div class="flex items-center justify-between"><span class="text-xs text-white/60">Sample block</span><span class="text-xs text-white/40">#{i + 1}</span></div>
              <div class="mt-3 h-12 rounded-xl bg-white/5 ring-1 ring-white/10"></div>
              <div class="mt-3 h-3 w-3/4 rounded bg-white/10"></div>
              <div class="mt-2 h-3 w-1/2 rounded bg-white/10"></div>
            </div>
          ))}
        </div>
      </div>

      <div class="lg:col-span-5 space-y-6">
        <div class="glass rounded-[var(--radius-2xl)] p-6 sm:p-8">
          <h2 class="text-lg font-semibold">Tailwind v4 tip</h2>
          <p class="mt-3 text-sm text-white/70">If you see errors like <span class="text-white">“Cannot apply unknown utility class”</span>, it’s usually because of <code class="rounded bg-black/30 px-1.5 py-0.5 text-white/80">@apply</code> inside scoped styles. The most robust approach in Astro is to style directly in markup with utility classes.</p>
        </div>

        <div class="glass rounded-[var(--radius-2xl)] p-6 sm:p-8">
          <h2 class="text-lg font-semibold">View transitions</h2>
          <p class="mt-3 text-sm text-white/70">Astro’s <code class="rounded bg-black/30 px-1.5 py-0.5 text-white/80">ClientRouter</code> adds smooth navigation and respects <code class="rounded bg-black/30 px-1.5 py-0.5 text-white/80">prefers-reduced-motion</code> automatically.</p>
          <a href="/pokemons/1" class="mt-5 inline-flex w-full items-center justify-center rounded-xl bg-white/5 px-4 py-3 text-sm font-semibold text-white/80 ring-1 ring-white/10 hover:bg-white/10 hover:text-white transition focus-visible:focus-ring">Try it in the Pokédex</a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
