---
import { siteInfo } from "../data/site-info";
const { pathname } = Astro.url;
const isActive = (href) => (pathname === href || pathname.startsWith(href + "/"));
---

<header class="sticky top-0 z-40">
  <!-- subtle blur / glass header -->
  <div class="relative noise">
    <div class="glass border-b border-white/10">
      <div class="safe-area mx-auto max-w-6xl">
        <div class="flex items-center justify-between gap-4 py-3">
          <a
            href="/"
            class="group inline-flex items-center gap-2 rounded-xl px-2 py-1 focus-visible:focus-ring"
            aria-label={`${siteInfo.title} home`}
          >
            <span
              class="grid size-9 place-items-center rounded-xl bg-white/5 ring-1 ring-white/10 transition group-hover:bg-white/10"
            >
              <span class="text-lg">⚡</span>
            </span>
            <span class="leading-tight">
              <span class="block text-sm font-semibold tracking-tight">
                <span class="text-gradient">{siteInfo.title}</span>
              </span>
              <span class="block text-xs text-white/60">{siteInfo.tagline}</span>
            </span>
          </a>

          <nav class="hidden items-center gap-1 md:flex" aria-label="Primary">
            <a
              href="/pokemons/1"
              class:list={[
                "rounded-xl px-3 py-2 text-sm transition focus-visible:focus-ring",
                isActive("/pokemons") ? "bg-white/10 text-white" : "text-white/70 hover:bg-white/5 hover:text-white",
              ]}
            >
              Pokédex
            </a>
            <a
              href="/about"
              class:list={[
                "rounded-xl px-3 py-2 text-sm transition focus-visible:focus-ring",
                isActive("/about") ? "bg-white/10 text-white" : "text-white/70 hover:bg-white/5 hover:text-white",
              ]}
            >
              About
            </a>
          </nav>

          <!-- Right actions -->
          <div class="flex items-center gap-2">
            <a
              href="https://astro.build"
              target="_blank"
              rel="noreferrer"
              class="hidden rounded-xl px-3 py-2 text-sm text-white/70 hover:bg-white/5 hover:text-white focus-visible:focus-ring sm:inline-flex"
            >
              Astro
            </a>

            <a
              href="/pokemons/1"
              class="inline-flex items-center gap-2 rounded-xl bg-white text-black px-3 py-2 text-sm font-semibold shadow-sm shadow-black/30 hover:translate-y-[-1px] hover:shadow-md transition focus-visible:focus-ring"
            >
              <span aria-hidden="true">Browse</span>
              <span class="text-black/70">→</span>
            </a>
          </div>
        </div>

        <!-- Mobile nav -->
        <div class="md:hidden pb-3">
          <div class="grid grid-cols-2 gap-2">
            <a
              href="/pokemons/1"
              class:list={[
                "rounded-xl px-3 py-2 text-center text-sm transition focus-visible:focus-ring",
                isActive("/pokemons") ? "bg-white/10 text-white" : "bg-white/5 text-white/70 hover:bg-white/10 hover:text-white",
              ]}
            >
              Pokédex
            </a>
            <a
              href="/about"
              class:list={[
                "rounded-xl px-3 py-2 text-center text-sm transition focus-visible:focus-ring",
                isActive("/about") ? "bg-white/10 text-white" : "bg-white/5 text-white/70 hover:bg-white/10 hover:text-white",
              ]}
            >
              About
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>
